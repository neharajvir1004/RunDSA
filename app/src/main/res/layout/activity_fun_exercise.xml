<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fun Exercises"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Practice DSA with mini games"
            android:textSize="15sp"
            android:textColor="#6B7280"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSortingGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sorting Game"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnBinarySearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Binary Search Hunt"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnDsaChallenge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DSA Challenge"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>