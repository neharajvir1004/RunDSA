<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardSubtype"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="#F7F9FC"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvSelectedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="#0D66C2"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="Selected"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSubtypeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bubble Sort"
        android:textColor="#0D66C2"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSubtypeDefinition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Definition"
        android:textColor="#444444"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvSubtypeCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#EEF1F5"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:text="Code"
        android:textColor="#0D3B66"
        android:textSize="14sp" />
</LinearLayout>